// FinNex Prisma schema. See ../09_database_schema.md for full design.
// Postgres 16. ULID-style IDs are stored as String (CHAR(26)) generated by app code.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// User & auth
// ---------------------------------------------------------------------------

model User {
  id                String    @id
  email             String?   @unique
  phoneE164         String?   @unique @map("phone_e164")
  passwordHash      String?   @map("password_hash")
  displayName       String?   @map("display_name")
  locale            String    @default("ru-KZ")
  timezone          String    @default("Asia/Almaty")
  primaryCurrency   String    @default("KZT") @map("primary_currency")
  countryCode       String    @default("KZ") @map("country_code")
  plan              String    @default("free")
  status            String    @default("active")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  phoneVerifiedAt   DateTime? @map("phone_verified_at")
  deletionRequestedAt DateTime? @map("deletion_requested_at")
  marketingConsent  Boolean   @default(false) @map("marketing_consent")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastSeenAt        DateTime? @map("last_seen_at")
  version           BigInt    @default(1)

  accounts        Account[]
  categories      Category[]
  transactions    Transaction[]
  budgets         Budget[]
  tags            Tag[]
  notifications   Notification[]
  insights        Insight[]
  settings        UserSetting?
  devices         Device[]
  sessions        Session[]
  syncQueueItems  SyncQueue[]
  auditLogs       AuditLog[]
  subscription    Subscription?
  paymentEvents   PaymentEvent[]
  onboarding      OnboardingProgress?
  streak          Streak?
  referralsMade   Referral[]   @relation("ReferralFrom")
  referralsRecvd  Referral[]   @relation("ReferralTo")
  exportJobs      ExportJob[]
  idempotencyKeys IdempotencyKey[]

  @@index([status, lastSeenAt(sort: Desc)])
  @@map("users")
}

model Session {
  id                String    @id
  userId            String    @map("user_id")
  deviceId          String?   @map("device_id")
  accessTokenHash   String    @map("access_token_hash")
  refreshTokenHash  String    @unique @map("refresh_token_hash")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  issuedAt          DateTime  @default(now()) @map("issued_at")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  revokeReason      String?   @map("revoke_reason")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id])

  @@index([userId, expiresAt(sort: Desc)])
  @@map("sessions")
}

model Device {
  id              String    @id
  userId          String    @map("user_id")
  platform        String
  deviceName      String?   @map("device_name")
  osVersion       String?   @map("os_version")
  appVersion      String?   @map("app_version")
  pushToken       String?   @map("push_token")
  pushTokenType   String?   @map("push_token_type")
  language        String?
  timezone        String?
  installId       String    @map("install_id")
  firstSeenAt     DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime  @default(now()) @map("last_seen_at")
  revokedAt       DateTime? @map("revoked_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([userId, installId])
  @@index([pushToken])
  @@map("devices")
}

// ---------------------------------------------------------------------------
// Accounts, categories, transactions
// ---------------------------------------------------------------------------

model Account {
  id                  String    @id
  userId              String    @map("user_id")
  typeCode            String    @map("type_code")
  name                String
  currency            String    @default("KZT")
  balanceMinor        BigInt    @default(0) @map("balance_minor")
  initialBalanceMinor BigInt    @default(0) @map("initial_balance_minor")
  creditLimitMinor    BigInt?   @map("credit_limit_minor")
  bankCode            String?   @map("bank_code")
  lastFour            String?   @map("last_four")
  color               String    @default("#1F8FFF")
  icon                String?
  isArchived          Boolean   @default(false) @map("is_archived")
  isPrimary           Boolean   @default(false) @map("is_primary")
  includeInTotal      Boolean   @default(true) @map("include_in_total")
  sortOrder           Int       @default(0) @map("sort_order")
  clientId            String    @unique @map("client_id")
  serverId            String?   @map("server_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  syncState           String    @default("synced") @map("sync_state")
  version             BigInt    @default(1)
  serverVersion       BigInt?   @map("server_version")
  lastSyncedAt        DateTime? @map("last_synced_at")
  dirty               Boolean   @default(false)
  deviceId            String?   @map("device_id")

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[] @relation("AccountTransactions")
  transfersIn         Transaction[] @relation("TransferTargetAccount")

  @@index([userId, sortOrder])
  @@index([userId, dirty])
  @@map("accounts")
}

model Category {
  id                String    @id
  userId            String?   @map("user_id")
  typeCode          String    @map("type_code")
  parentId          String?   @map("parent_id")
  name              String
  nameI18nKey       String?   @map("name_i18n_key")
  icon              String
  color             String    @default("#888888")
  isSystem          Boolean   @default(false) @map("is_system")
  isArchived        Boolean   @default(false) @map("is_archived")
  sortOrder         Int       @default(0) @map("sort_order")
  monthlyLimitMinor BigInt?   @map("monthly_limit_minor")
  clientId          String    @unique @map("client_id")
  serverId          String?   @map("server_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  syncState         String    @default("synced") @map("sync_state")
  version           BigInt    @default(1)
  serverVersion     BigInt?   @map("server_version")
  lastSyncedAt      DateTime? @map("last_synced_at")
  dirty             Boolean   @default(false)
  deviceId          String?   @map("device_id")

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryParent", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryParent")
  transactions Transaction[]
  budgets      Budget[]      @relation("BudgetCategories")

  @@index([userId, typeCode])
  @@index([parentId])
  @@map("categories")
}

model Transaction {
  id                   String    @id
  userId               String    @map("user_id")
  accountId            String    @map("account_id")
  typeCode             String    @map("type_code")
  categoryId           String?   @map("category_id")
  amountMinor          BigInt    @map("amount_minor")
  currency             String
  fxRate               Decimal?  @map("fx_rate") @db.Decimal(18, 8)
  amountPrimaryMinor   BigInt?   @map("amount_primary_minor")
  occurredAt           DateTime  @map("occurred_at")
  note                 String?
  description          String?
  transferAccountId    String?   @map("transfer_account_id")
  transferGroupId      String?   @map("transfer_group_id")
  source               String    @default("manual")
  externalRef          String?   @map("external_ref")
  hasAttachment        Boolean   @default(false) @map("has_attachment")
  lat                  Float?
  lng                  Float?
  clientId             String    @unique @map("client_id")
  serverId             String?   @map("server_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")
  syncState            String    @default("synced") @map("sync_state")
  version              BigInt    @default(1)
  serverVersion        BigInt?   @map("server_version")
  lastSyncedAt         DateTime? @map("last_synced_at")
  dirty                Boolean   @default(false)
  deviceId             String?   @map("device_id")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         Account          @relation("AccountTransactions", fields: [accountId], references: [id])
  transferAccount Account?         @relation("TransferTargetAccount", fields: [transferAccountId], references: [id])
  category        Category?        @relation(fields: [categoryId], references: [id])
  tags            TransactionTag[]

  @@index([userId, occurredAt(sort: Desc)])
  @@index([accountId, occurredAt(sort: Desc)])
  @@index([userId, categoryId, occurredAt(sort: Desc)])
  @@index([userId, typeCode, occurredAt(sort: Desc)])
  @@index([userId, dirty])
  @@index([transferGroupId])
  @@index([userId, source, externalRef])
  @@map("transactions")
}

model Tag {
  id            String    @id
  userId        String    @map("user_id")
  name          String
  color         String    @default("#888888")
  usageCount    Int       @default(0) @map("usage_count")
  clientId      String    @unique @map("client_id")
  serverId      String?   @map("server_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  syncState     String    @default("synced") @map("sync_state")
  version       BigInt    @default(1)
  serverVersion BigInt?   @map("server_version")
  lastSyncedAt  DateTime? @map("last_synced_at")
  dirty         Boolean   @default(false)
  deviceId      String?   @map("device_id")

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions TransactionTag[]

  @@unique([userId, name])
  @@index([userId, usageCount(sort: Desc)])
  @@map("tags")
}

model TransactionTag {
  transactionId String   @map("transaction_id")
  tagId         String   @map("tag_id")
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@index([tagId])
  @@map("transaction_tags")
}

// ---------------------------------------------------------------------------
// Budgets
// ---------------------------------------------------------------------------

model Budget {
  id              String    @id
  userId          String    @map("user_id")
  name            String
  periodCode      String    @default("monthly") @map("period_code")
  amountMinor     BigInt    @map("amount_minor")
  currency        String    @default("KZT")
  scope           String    @default("category")
  categoryIds     String[]  @map("category_ids")
  accountIds      String[]  @map("account_ids")
  startsOn        DateTime  @map("starts_on") @db.Date
  endsOn          DateTime? @map("ends_on") @db.Date
  rolloverUnspent Boolean   @default(false) @map("rollover_unspent")
  alertThresholds Int[]     @default([80]) @map("alert_thresholds")
  alertAtPercent  Int       @default(80) @map("alert_at_percent")
  isActive        Boolean   @default(true) @map("is_active")
  clientId        String    @unique @map("client_id")
  serverId        String?   @map("server_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  syncState       String    @default("synced") @map("sync_state")
  version         BigInt    @default(1)
  serverVersion   BigInt?   @map("server_version")
  lastSyncedAt    DateTime? @map("last_synced_at")
  dirty           Boolean   @default(false)
  deviceId        String?   @map("device_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories Category[] @relation("BudgetCategories")

  @@index([userId, isActive])
  @@map("budgets")
}

// ---------------------------------------------------------------------------
// Notifications / insights
// ---------------------------------------------------------------------------

model Notification {
  id            String    @id
  userId        String    @map("user_id")
  kind          String
  title         String
  body          String
  payload       Json?
  priority      Int       @default(5)
  scheduledAt   DateTime? @map("scheduled_at")
  sentAt        DateTime? @map("sent_at")
  readAt        DateTime? @map("read_at")
  dismissedAt   DateTime? @map("dismissed_at")
  channel       String    @default("push")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([scheduledAt])
  @@map("notifications")
}

model Insight {
  id           String    @id
  userId       String    @map("user_id")
  kind         String
  title        String
  body         String
  severity     String    @default("info")
  payload      Json?
  generatedAt  DateTime  @default(now()) @map("generated_at")
  expiresAt    DateTime? @map("expires_at")
  dismissedAt  DateTime? @map("dismissed_at")
  actedAt      DateTime? @map("acted_at")
  score        Decimal?  @db.Decimal(5, 2)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, generatedAt(sort: Desc)])
  @@map("insights")
}

// ---------------------------------------------------------------------------
// User settings
// ---------------------------------------------------------------------------

model UserSetting {
  userId                    String    @id @map("user_id")
  theme                     String    @default("system")
  weekStartsOn              Int       @default(1) @map("week_starts_on")
  numberFormat              String    @default("ru-KZ") @map("number_format")
  decimalSeparator          String    @default(",") @map("decimal_separator")
  thousandSeparator         String    @default(" ") @map("thousand_separator")
  hideBalancesUntilAuth     Boolean   @default(false) @map("hide_balances_until_auth")
  biometricLock             Boolean   @default(false) @map("biometric_lock")
  defaultAccountId          String?   @map("default_account_id")
  defaultExpenseCategoryId  String?   @map("default_expense_category_id")
  defaultIncomeCategoryId   String?   @map("default_income_category_id")
  quickAddAmounts           Int[]     @default([500, 1000, 2000, 5000]) @map("quick_add_amounts")
  budgetCarryoverDefault    Boolean   @default(false) @map("budget_carryover_default")
  dailyReminderTime         String?   @map("daily_reminder_time")
  showAccountTotalOnHome    Boolean   @default(true) @map("show_account_total_on_home")
  language                  String    @default("ru")
  notificationPreferences   Json?     @map("notification_preferences")
  updatedAt                 DateTime  @updatedAt @map("updated_at")
  version                   BigInt    @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ---------------------------------------------------------------------------
// Sync / audit
// ---------------------------------------------------------------------------

model SyncQueue {
  id            BigInt   @id @default(autoincrement())
  userId        String   @map("user_id")
  entityTable   String   @map("entity_table")
  entityId      String   @map("entity_id")
  op            String
  payload       Json
  enqueuedAt    DateTime @default(now()) @map("enqueued_at")
  attempts      Int      @default(0)
  lastAttemptAt DateTime? @map("last_attempt_at")
  lastError     String?  @map("last_error")
  status        String   @default("pending")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("sync_queue")
}

model AuditLog {
  id            String    @id
  userId        String?   @map("user_id")
  userIdHash    String?   @map("user_id_hash")
  actorType     String    @map("actor_type")
  eventType     String    @map("event_type")
  eventSubtype  String?   @map("event_subtype")
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")
  deviceId      String?   @map("device_id")
  sessionId     String?   @map("session_id")
  resourceType  String?   @map("resource_type")
  resourceId    String?   @map("resource_id")
  metadata      Json?
  severity      String    @default("info")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("audit_log")
}

model IdempotencyKey {
  key           String   @id
  userId        String   @map("user_id")
  endpoint      String
  requestHash   String   @map("request_hash")
  responseBody  Json?    @map("response_body")
  responseStatus Int     @map("response_status")
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endpoint])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ---------------------------------------------------------------------------
// Subscriptions / payments
// ---------------------------------------------------------------------------

model Subscription {
  id                  String    @id
  userId              String    @unique @map("user_id")
  plan                String    @default("free")
  status              String    @default("active")
  store               String?
  productId           String?   @map("product_id")
  startedAt           DateTime? @map("started_at")
  currentPeriodEnd    DateTime? @map("current_period_end")
  autoRenew           Boolean   @default(false) @map("auto_renew")
  cancelledAt         DateTime? @map("cancelled_at")
  inGracePeriod       Boolean   @default(false) @map("in_grace_period")
  rawReceipt          String?   @map("raw_receipt")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model PaymentEvent {
  id              String   @id
  userId          String   @map("user_id")
  store           String
  eventType       String   @map("event_type")
  transactionId   String?  @map("transaction_id")
  productId       String?  @map("product_id")
  payload         Json
  receivedAt      DateTime @default(now()) @map("received_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, receivedAt(sort: Desc)])
  @@map("payment_events")
}

// ---------------------------------------------------------------------------
// Reference data, feature flags, onboarding, streaks, referrals, FX
// ---------------------------------------------------------------------------

model ExchangeRate {
  id           String   @id
  base         String
  quote        String
  rate         Decimal  @db.Decimal(18, 8)
  asOf         DateTime @map("as_of")
  source       String   @default("manual")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([base, quote, asOf])
  @@index([base, quote, asOf(sort: Desc)])
  @@map("exchange_rates")
}

model FeatureFlag {
  id              String    @id
  key             String
  userId          String?   @map("user_id")
  segment         String?
  enabled         Boolean   @default(false)
  payload         Json?
  rolloutPercent  Int?      @map("rollout_percent")
  startsAt        DateTime? @map("starts_at")
  endsAt          DateTime? @map("ends_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([key, userId])
  @@index([key, segment])
  @@map("feature_flags")
}

model OnboardingProgress {
  userId          String    @id @map("user_id")
  step            String    @default("welcome")
  stepsCompleted  String[]  @default([]) @map("steps_completed")
  completedAt     DateTime? @map("completed_at")
  skippedAt       DateTime? @map("skipped_at")
  abVariant       String?   @map("ab_variant")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  version         BigInt    @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}

model Streak {
  userId             String    @id @map("user_id")
  currentStreakDays  Int       @default(0) @map("current_streak_days")
  longestStreakDays  Int       @default(0) @map("longest_streak_days")
  lastActiveDate     DateTime? @map("last_active_date") @db.Date
  totalActiveDays    Int       @default(0) @map("total_active_days")
  frozenUntil        DateTime? @map("frozen_until") @db.Date
  updatedAt          DateTime  @updatedAt @map("updated_at")
  version            BigInt    @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model Referral {
  id              String    @id
  code            String    @unique
  fromUserId      String    @map("from_user_id")
  toUserId        String?   @map("to_user_id")
  status          String    @default("pending")
  rewardAmountMinor BigInt? @map("reward_amount_minor")
  rewardCurrency  String?   @map("reward_currency")
  redeemedAt      DateTime? @map("redeemed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  fromUser User  @relation("ReferralFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User? @relation("ReferralTo", fields: [toUserId], references: [id], onDelete: SetNull)

  @@index([fromUserId])
  @@map("referrals")
}

model ExportJob {
  id            String    @id
  userId        String    @map("user_id")
  format        String
  fromDate      DateTime  @map("from_date") @db.Date
  toDate        DateTime  @map("to_date") @db.Date
  entities      String[]
  status        String    @default("queued")
  progress      Float     @default(0)
  downloadUrl   String?   @map("download_url")
  expiresAt     DateTime? @map("expires_at")
  errorMessage  String?   @map("error_message")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("export_jobs")
}
