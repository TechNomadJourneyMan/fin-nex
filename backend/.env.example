# FinNex backend — environment template.
# Copy to .env and fill in for local development.

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (Postgres)
DATABASE_URL=postgresql://finnex:finnex@localhost:5432/finnex?schema=public

# Cache / queue (Redis)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
