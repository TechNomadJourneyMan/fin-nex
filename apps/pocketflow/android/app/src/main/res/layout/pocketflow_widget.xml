<?xml version="1.0" encoding="utf-8"?>
<!-- Pocket Flow home-screen widget layout (RemoteViews). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/pocketflow_widget_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pocket Flow"
        android:textSize="11sp"
        android:textColor="#99FFFFFF" />

    <TextView
        android:id="@+id/pf_widget_balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="—"
        android:textStyle="bold"
        android:textSize="22sp"
        android:maxLines="1"
        android:textColor="#FFFFFFFF" />

    <LinearLayout
        android:id="@+id/pf_widget_next_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next payment"
            android:textSize="11sp"
            android:textColor="#99FFFFFF" />

        <TextView
            android:id="@+id/pf_widget_next_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF" />

        <TextView
            android:id="@+id/pf_widget_next_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#99FFFFFF" />
    </LinearLayout>
</LinearLayout>
